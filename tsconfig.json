{
    "compilerOptions": {
        "baseUrl": "src",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES6",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "node",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "types": [
            "node",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "wdio-obsidian-service"
        ],
        "lib": ["DOM", "ES5", "ES6", "ES7", "ESNext"]
    },
    "include": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "test/**/*.ts",
        "wdio.conf.mts",
        "docs/**/*"
    ]
}
